# Server-only production variables.
# Put these in your hosting provider's encrypted environment settings, not in client-exposed config.

SITE_URL=https://productplate.pages.dev
BETTER_AUTH_SECRET=

# Convex server/deploy variables.
CONVEX_DEPLOYMENT=prod:your-project-123

# Google OAuth
# Configure in Google Cloud Console -> APIs & Services -> Credentials.
# Authorized JavaScript origins:
# - https://productplate.pages.dev
# Authorized redirect URIs:
# - https://productplate.pages.dev/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend email delivery.
RESEND_API_KEY=
RESET_EMAIL_FROM="Product Plate <no-reply@example.com>"
RESET_EMAIL_REPLY_TO=

# OpenRouter for the Vercel AI SDK route at /api/chat.
# Model used by default: openrouter/free.
OPENROUTER_API_KEY=

# Autumn Billing
AUTUMN_SECRET_KEY=
